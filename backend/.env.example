# 🔒 Environment Configuration
# Copy to .env and fill with actual values
# NEVER commit .env to git!

# Spring Boot
SPRING_PROFILES_ACTIVE=development
SERVER_PORT=8080
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# Database
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/myapp
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your-secure-password

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_EXPIRATION=86400000

# Security
SPRING_SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:3000
SPRING_SECURITY_OAUTH_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
SPRING_SECURITY_OAUTH_GOOGLE_CLIENT_SECRET=your-secret

# AWS (if using)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=eu-west-1

# Email
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=your-email@gmail.com
MAIL_SMTP_PASSWORD=your-app-password

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_EXAMPLE=DEBUG

# API Keys
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx